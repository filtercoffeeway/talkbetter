# Copy this file to `.env` and fill in your keys.
# Phase 1 needs NONE of these — it runs fully local.

# ---- App ----
APP_HOST=127.0.0.1
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173   # Vite dev server

# ---- Whisper (Phase 1) ----
# tiny | base | small | medium | large-v3  (bigger = slower, more accurate)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu                   # "cpu" or "cuda"
WHISPER_COMPUTE_TYPE=int8            # int8 (cpu) | float16 (gpu)

# ---- LLM for grammar + clarity (Phase 2) ----
LLM_PROVIDER=anthropic               # "anthropic" or "openai"
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# ---- Azure Pronunciation Assessment (Phase 3) ----
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=                 # e.g. eastus
